# D2RE .gitignore

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/
.tox/
.venv/
venv/
env/
pip-wheel-metadata/

# ── Data files — DO NOT commit game files ────────────────────────────────────
# MPQ archives (copyrighted by Blizzard)
*.mpq
*.MPQ

# CASC storage directories
.build.info
.cdn.info
Diablo\ II\ Resurrected/

# Extracted data tables (generated by mpq_extract.py)
data_tables/
tables/
extracted/

# D2 save files (personal data)
*.d2s
*.d2i

# Packet captures (potentially contain personal info)
*.pcap
*.pcapng
*.cap

# ── Analysis output ───────────────────────────────────────────────────────────
session.json
*.session.json
d2_offsets_export.json
tc_tree.json
strings.json

# ── IDA / Ghidra project files ────────────────────────────────────────────────
*.i64
*.id0
*.id1
*.id2
*.nam
*.til
*.idb
.ghidra/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*~

# ── Windows ───────────────────────────────────────────────────────────────────
# D2 binaries — copyrighted
Diablo\ II.exe
D2Common.dll
D2Game.dll
D2Client.dll
D2Net.dll
D2Win.dll
D2Gfx.dll
D2Sound.dll
D2CMP.dll
D2Lang.dll
Fog.dll
Storm.dll
BNClient.dll

# Compiled DLLs from hook experiments
*.dll
!requirements.txt
